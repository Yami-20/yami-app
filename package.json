{
  "name": "yami",
  "version": "1.3.0",
  "description": "Yami — a sleek, intelligent music player with radio mode and smart song suggestions.",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "author": {
    "name": "Yami",
    "email": "yami@yami.app",
    "url": "https://github.com/Yami-20/yami-app"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.16.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.21.0",
    "wait-on": "^8.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "bundle-server": "esbuild server.js --bundle --platform=node --outfile=build-resources/server.bundle.js --external:yt-dlp",
    "test": "react-scripts test",
    "electron:dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && npm run bundle-server && electron-builder",
    "electron:build:win": "npm run build && npm run bundle-server && electron-builder --win",
    "electron:build:linux": "npm run build && npm run bundle-server && electron-builder --linux",
    "cap:init": "npx cap init yami com.yami.app",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.yami.app",
    "productName": "Yami",
    "copyright": "Copyright © 2026 Yami",
    "extends": null,
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "build/**/*",
      "electron/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "electronVersion": "31.0.0",
    "linux": {
      "icon": "build-resources/icon.png",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio",
      "executableArgs": [
        "--no-sandbox"
      ],
      "maintainer": "Yami <yami@yami.app>",
      "extraResources": [
        {
          "from": "build-resources/server.bundle.js",
          "to": "server.bundle.js"
        },
        {
          "from": "build-resources/yt-dlp",
          "to": "yt-dlp"
        }
      ],
      "desktop": {
        "Name": "Yami",
        "Comment": "Music player",
        "Categories": "Audio;Music;Player;"
      }
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "build-resources/server.bundle.js",
          "to": "server.bundle.js"
        },
        {
          "from": "build-resources/yt-dlp.exe",
          "to": "yt-dlp.exe"
        }
      ]
    },
    "mac": {
      "icon": "build-resources/icon.png",
      "category": "public.app-category.music"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yami-20/yami-app.git"
  },
  "keywords": [
    "music",
    "player",
    "electron",
    "react",
    "radio"
  ]
}
